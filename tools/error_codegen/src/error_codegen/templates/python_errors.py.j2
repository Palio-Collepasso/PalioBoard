"""Generated Python error definitions for the `{{ module_name }}` module."""

from palio.shared.errors.base import ErrorDefinition

MODULE_NAME = {{ module_name | python_literal }}

{% for entry in entries %}
{{ entry.code }} = ErrorDefinition(
    code={{ entry.code | python_literal }},
    module_name=MODULE_NAME,
    type_slug={{ entry.type_slug | python_literal }},
    type_uri={{ entry.type_uri | python_literal }},
    http_status={{ entry.http_status | python_literal }},
    title={{ entry.title | python_literal }},
    description={{ entry.description | python_literal }},
    category={{ entry.category | python_literal }},
    retry_policy={{ entry.retry_policy | python_literal }},
    safe_to_expose={{ entry.safe_to_expose | python_literal }},
    translation_key={{ entry.translation_key | python_literal }},
    log_level={{ entry.log_level | python_literal }},
    severity={{ entry.severity | python_literal }},
{{ render_python_field("context_schema", entry.resolved_context_schema) }}
    notes_for_operators={{ entry.notes_for_operators | python_literal }},
)

{% endfor %}
ERROR_DEFINITIONS: tuple[ErrorDefinition, ...] = (
{% for entry in entries %}
    {{ entry.code }},
{% endfor %}
)
ERROR_DEFINITIONS_BY_CODE: dict[str, ErrorDefinition] = {
{% for entry in entries %}
    {{ entry.code }}.code: {{ entry.code }},
{% endfor %}
}
ERROR_CODES: tuple[str, ...] = tuple(
    error_definition.code for error_definition in ERROR_DEFINITIONS
)

__all__ = [
{% for name in export_names %}
    "{{ name }}",
{% endfor %}
]
